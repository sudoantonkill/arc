# Supabase Configuration
# Get these values from your Supabase project: Settings -> API

VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Example (replace with your actual values):
# VITE_SUPABASE_URL=https://abcdefghijk.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# RAZORPAY CONFIGURATION (Payments)
# ============================================
# Get these from your Razorpay Dashboard: https://dashboard.razorpay.com/app/keys

# Client-side Key ID (safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# ============================================
# DAILY.CO CONFIGURATION (Video Calling)
# ============================================
# Get these from your Daily.co Dashboard: https://dashboard.daily.co

# API Key for creating rooms (used in Edge Functions only - not exposed to client)
# DAILY_API_KEY=your_daily_api_key_here

# ============================================
# SUPABASE EDGE FUNCTION SECRETS
# ============================================
# These are set via Supabase CLI, not in this file:
# supabase secrets set RAZORPAY_KEY_ID=rzp_test_...
# supabase secrets set RAZORPAY_KEY_SECRET=...
# supabase secrets set DAILY_API_KEY=...
# supabase secrets set RESEND_API_KEY=re_...
# supabase secrets set FRONTEND_URL=https://your-domain.com
