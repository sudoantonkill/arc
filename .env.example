# Supabase Configuration
# Get these values from your Supabase project: Settings -> API

VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Example (replace with your actual values):
# VITE_SUPABASE_URL=https://abcdefghijk.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# RAZORPAY CONFIGURATION (Payments - INR)
# ============================================
# Get these from your Razorpay Dashboard: https://dashboard.razorpay.com/app/keys
#
# For LIVE mode, use keys starting with rzp_live_
# For TEST mode, use keys starting with rzp_test_

# Client-side Key ID (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_live_your_key_id_here

# ============================================
# SUPABASE EDGE FUNCTION SECRETS
# ============================================
# These are NOT put in .env — they are set via Supabase CLI:
#
# supabase secrets set RAZORPAY_KEY_ID=rzp_live_XXXX
# supabase secrets set RAZORPAY_KEY_SECRET=your_secret_here
# supabase secrets set FRONTEND_URL=https://your-deployed-url.vercel.app
# supabase secrets set RESEND_API_KEY=re_...
